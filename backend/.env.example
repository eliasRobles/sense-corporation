# Backend Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Microsoft 365 Email Configuration
# Register an app in Azure AD with Mail.Send permissions
# https://portal.azure.com -> Azure Active Directory -> App registrations
MICROSOFT_TENANT_ID=your-tenant-id-here
MICROSOFT_CLIENT_ID=your-client-id-here
MICROSOFT_CLIENT_SECRET=your-client-secret-here
MICROSOFT_EMAIL_FROM=info@sense-corporation.com
MAIL_TO=info@sensecorp.com
